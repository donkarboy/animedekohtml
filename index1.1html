<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Stream Extractor</title>
</head>
<body>
<pre id="output">Extracting...</pre>
<script>
async function getStream(embedUrl) {
    const corsProxy = "https://corsproxy.io/?url=";

    const htmlResponse = await fetch(corsProxy + encodeURIComponent(embedUrl));
    const html = await htmlResponse.text();

    const hashMatch = html.match(/\/video\/([a-f0-9]{32})/);
    if (!hashMatch) throw new Error("Hash not found in HTML source.");

    const hash = hashMatch[1];
    const cdnVideoUrl = `https://as-cdn21.top/video/${hash}`;

    await fetch(corsProxy + encodeURIComponent(cdnVideoUrl));

    const apiUrl = `https://as-cdn21.top/player/index.php?data=${hash}&do=getVideo`;

    const formData = new URLSearchParams();
    formData.append("hash", hash);
    formData.append("r", "https://animedekho.app/");

    const apiResponse = await fetch(corsProxy + encodeURIComponent(apiUrl), {
        method: "POST",
        headers: {
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "X-Requested-With": "XMLHttpRequest"
        },
        body: formData
    });

    if (!apiResponse.ok) throw new Error(`API returned status: ${apiResponse.status}`);

    const data = await apiResponse.json();

    return {
        embed_url: embedUrl,
        cdn_video_page: cdnVideoUrl,
        hash: hash,
        stream_url: data.videoSource,
        raw_api_response: data
    };
}

async function init() {
    const out = document.getElementById("output");

    // Method 1: query params  ?id=31910&ep=1-25
    const params = new URLSearchParams(window.location.search);
    let tmdbId = params.get("id");
    let episodeStr = params.get("ep");

    // Method 2: hash  #/31910/1-25
    if (!tmdbId || !episodeStr) {
        const hashMatch = window.location.hash.match(/\/?(\d+)\/([\d]+-[\d]+)/);
        if (hashMatch) {
            tmdbId = hashMatch[1];
            episodeStr = hashMatch[2];
        }
    }

    // Method 3: GitHub Pages 404 redirect stores original path in sessionStorage
    if (!tmdbId || !episodeStr) {
        const redirected = sessionStorage.getItem("gh_redirect");
        if (redirected) {
            sessionStorage.removeItem("gh_redirect");
            const m = redirected.match(/\/(\d+)\/([\d]+-[\d]+)/);
            if (m) { tmdbId = m[1]; episodeStr = m[2]; }
        }
    }

    if (!tmdbId || !episodeStr) {
        out.textContent = JSON.stringify({
            error: "No TMDB ID or episode found. Use one of these URL formats:",
            formats: {
                query_params: "https://donkarboy.github.io/animedekohtml/?id=31910&ep=1-25",
                hash: "https://donkarboy.github.io/animedekohtml/#/31910/1-25",
                path_via_404: "https://donkarboy.github.io/animedekohtml/31910/1-25"
            }
        }, null, 2);
        return;
    }

    const embedUrl = `https://animedekho.app/embed/${tmdbId}/${episodeStr}`;

    try {
        const result = await getStream(embedUrl);
        out.textContent = JSON.stringify(result, null, 2);
    } catch (err) {
        out.textContent = JSON.stringify({
            error: err.message,
            embed_url: embedUrl
        }, null, 2);
    }
}

init();
</script>
</body>
</html>